# ShiftWorker environment variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloud provider (oracle | digitalocean | hetzner)
CLOUD_PROVIDER=oracle

# Oracle Cloud — Always Free tier (primary provider)
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxx
OCI_USER_OCID=ocid1.user.oc1..xxx
OCI_KEY_FINGERPRINT=xx:xx:xx...
OCI_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
OCI_REGION=us-phoenix-1
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..xxx
OCI_SUBNET_OCID=ocid1.subnet.oc1..xxx

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# DigitalOcean OAuth — paid tier (future)
# DO_CLIENT_ID=
# DO_CLIENT_SECRET=
# DO_REDIRECT_URI=

# Encryption key for storing provider OAuth tokens (openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# Resend (email)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron
CRON_SECRET=

# Admin — comma-separated list of admin email addresses
ADMIN_EMAILS=
