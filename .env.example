# HandsOff environment variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# DigitalOcean OAuth — users connect their own DO account
DO_CLIENT_ID=
DO_CLIENT_SECRET=
DO_REDIRECT_URI=

# Encryption key for storing provider OAuth tokens (openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# Resend (email)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron
CRON_SECRET=

# Admin — comma-separated list of admin email addresses
ADMIN_EMAILS=
