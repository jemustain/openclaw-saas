{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "claw4all-app.vercel.app"
        }
      ],
      "destination": "https://shiftworker.ai/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scheduler",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/vm-scheduler",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/enforce-limits",
      "schedule": "0 0 * * *"
    }
  ]
}
