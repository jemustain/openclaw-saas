# =============================================================================
# ShiftWorker Environment Variables
# Copy this file to .env.local and fill in your values.
# See docs/SETUP.md for step-by-step instructions.
# See docs/ENV_VARS.md for detailed descriptions.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Database + Auth)
# Get these from: Supabase Dashboard → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Stripe (Payments)
# Get keys from: Stripe Dashboard → Developers → API keys
# Get price IDs from: Stripe Dashboard → Products → [product] → Price ID
# Get webhook secret from: Stripe Dashboard → Developers → Webhooks → endpoint
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# -----------------------------------------------------------------------------
# Oracle Cloud — Always Free tier (primary provider)
# Get from: Oracle Cloud Console → Identity → Users → API Keys
# -----------------------------------------------------------------------------
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxx
OCI_USER_OCID=ocid1.user.oc1..xxx
OCI_KEY_FINGERPRINT=xx:xx:xx...
OCI_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
OCI_REGION=us-phoenix-1
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..xxx
OCI_SUBNET_OCID=ocid1.subnet.oc1..xxx

# -----------------------------------------------------------------------------
# DigitalOcean (VM Hosting) — paid tier (future)
# Get from: DigitalOcean → API → Generate New Token (read/write)
# Note: Hetzner support is planned for a future release.
# -----------------------------------------------------------------------------
# DO_API_TOKEN=your-digitalocean-token

# -----------------------------------------------------------------------------
# Resend (Email)
# Get from: resend.com → API Keys → Create
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Your app's public URL (Vercel deployment URL or custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloud provider
CLOUD_PROVIDER=oracle

# Secret for authenticating cron job endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret


# Telegram (Bot Factory — MTProto automation)
# Get API ID and hash from https://my.telegram.org
# Session string is generated once by running the auth script
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
